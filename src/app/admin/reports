import { redirect } from 'next/navigation'
import { createServerClient } from '@supabase/ssr'
import { cookies } from 'next/headers'
import { getSupabaseAdminClient } from '@/lib/supabaseAdmin'

export default async function AdminReportsPage() {
  const supabase = getSupabaseAdminClient()

  const { data: reports } = await supabase
    .from('reportes_ugc')
    .select(`
      id,
      motivo,
      created_at,
      user_id,
      avaliacao_id,
      avaliacoes (
        review_text
      )
    `)
    .order('created_at', { ascending: false })

  return (
    <main className="min-h-screen bg-black p-6 text-white">
      <h1 className="text-2xl font-bold mb-6 text-[#D4AF37]">
        Denúncias de Conteúdo
      </h1>

      <div className="space-y-4">
        {reports?.map((r) => (
          <div
            key={r.id}
            className="border border-zinc-800 rounded-xl p-4 bg-zinc-900"
          >
            <p className="text-sm text-red-400 font-semibold">
              {r.motivo}
            </p>

            <p className="mt-2 text-zinc-300 text-sm">
              {r.avaliacoes?.review_text}
            </p>

            <p className="text-xs text-zinc-500 mt-2">
              {new Date(r.created_at).toLocaleString()}
            </p>
            function isAdminEmail(email?: string | null) {
            return email === 'contato@confiamais.net'
            }
            <div className="flex gap-3 mt-4">
              <button className="bg-red-600 px-3 py-1 rounded">
                Remover avaliação
              </button>

              <button className="bg-zinc-700 px-3 py-1 rounded">
                Ignorar
              </button>
            </div>
          </div>
        ))}
      </div>
    </main>
  )
}
